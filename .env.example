# ─────────────────────────────────────────────────────────────────────────────
#  MyHomeschoolCurriculum — Environment Configuration
#  Copy this file to .env and fill in your values.
#  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── SERVER ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# The public URL of your site (no trailing slash)
# Production example: https://myhomeschoolcurriculum.com
myhomeschoolcurriculum.com=http://localhost:3001

# ── ADMIN ────────────────────────────────────────────────────────────────────
# Change this to a long random string before deploying!
# Generate one: openssl rand -hex 32
ADMIN_TOKEN=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# Email address that receives admin notifications
ADMIN_EMAIL=admin@yoursite.com

# ── EMAIL (SMTP) ──────────────────────────────────────────────────────────────
# Used for: welcome emails, password resets, new review notifications,
#           new inquiry notifications, contact form auto-replies.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=yourname@gmail.com
#   SMTP_PASS=your-app-password   ← Create at myaccount.google.com/apppasswords
#
# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=your-sendgrid-api-key
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── STRIPE (OPTIONAL) ─────────────────────────────────────────────────────────
# Required for publisher subscription billing.
# Get your keys at: https://dashboard.stripe.com/apikeys
# The server starts without Stripe — billing endpoints return 503 until configured.
#
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Create these Price IDs in your Stripe dashboard:
# Products → Add product → set recurring monthly price
STRIPE_PRICE_SILVER=       # $49/month — Silver listing
STRIPE_PRICE_GOLD=         # $149/month — Gold listing
STRIPE_PRICE_PLATINUM=     # $299/month — Platinum listing

# ── MAILCHIMP (OPTIONAL) ─────────────────────────────────────────────────────
# If set, newsletter subscribers are automatically synced to Mailchimp.
# Without this, subscribers are stored locally only (still works fine).
#
# Get your API key at: https://mailchimp.com/help/about-api-keys/
# Server prefix is the last part of your API key (e.g., "us1" from "abc123-us1")
#
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_LIST_ID=

# ── GOOGLE ANALYTICS (OPTIONAL) ──────────────────────────────────────────────
# Paste your GA4 Measurement ID into the frontend/index.html <head> tag:
# <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
# (Not required in .env — just add the tag to your HTML files)
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── CORS (PRODUCTION) ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production.
# Leave blank in development (allows all origins).
# ALLOWED_ORIGINS=https://myhomeschoolcurriculum.com,https://www.myhomeschoolcurriculum.com
